# Copy to .env in this folder and adjust if your dev server / DB differ.
# The suite uses the LIVE dev DB (per design — core maintenance focus, not a
# pristine isolated DB). Cleanup is the responsibility of each test.

# Base URL of the running EverShop instance. User must `npm run dev` from
# /Users/thenguyenhuu/vscode/evershop/core before invoking the suite.
BASE_URL=http://localhost:3000

# Postgres connection string. Used for:
#   - Creating + tearing down the test admin user.
#   - Cleaning up widget_instance rows whose name starts with `e2e-`.
#   - DB-level assertions inside specs (changeset_operation, widget_placement).
DATABASE_URL=postgres://root@localhost:5432/evershop

# Number of Playwright workers. e2e tests share the same DB, so parallelism
# is limited unless tests are written with strict per-test isolation.
# Start with 1; bump to 2-3 once we've validated isolation patterns.
PLAYWRIGHT_WORKERS=1
