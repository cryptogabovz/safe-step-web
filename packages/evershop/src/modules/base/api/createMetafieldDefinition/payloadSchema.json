    },
    "referenceType": { "type": "string" },
    "isList": { "type": "boolean" },
    "required": { "type": "boolean" },
    "translatable": { "type": "boolean" },
    "visibleToCustomer": { "type": "boolean" },
    "validations": { "type": "array" },
    "appearance": { "type": "object" },
    "subFields": { "type": "array" },
    "position": { "type": "integer" }
  },
  "errorMessage": {
    "required": {
      "ownerType": "ownerType is required",
      "fieldKey": "fieldKey is required",
      "name": "Field name is required",
      "fieldType": "fieldType is required"
    },
    "additionalProperties": "Unknown property in body — check the payload keys"
