# ============================================================
# SafeStep — Variables de entorno
# En Dokploy: pega cada variable en la sección Environment Variables.
# ============================================================

# ── Base de datos ────────────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=CambiaEstePassword123!
DB_NAME=postgres

# ── URL del sitio (REQUERIDO — corrige links en header/footer/emails) ──
EVERSHOP_HOME_URL=https://aresafestep.com

# ── Admin del panel ──────────────────────────────────────────
# Se crea automáticamente en cada deploy si no existe.
ADMIN_EMAIL=admin@aresafestep.com
ADMIN_PASSWORD=OtraClaveSegura456!
ADMIN_NAME=Administrador

# ── GoHighLevel (formulario de contacto) ─────────────────────
GHL_LOCATION_ID=tu_location_id_aqui
GHL_API_KEY=tu_api_key_aqui
