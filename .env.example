# ============================================================
# SafeStep — Variables de entorno
# Copia este archivo como .env y rellena los valores reales.
# En Dokploy: pega cada variable en la sección Environment Variables.
# ============================================================

# ── Base de datos ────────────────────────────────────────────
# Dokploy crea la BD automáticamente. Usa los mismos valores
# en el servicio PostgreSQL y en el servicio App.
DB_USER=safestep
DB_PASSWORD=CambiaEstePassword123!
DB_NAME=safestep_db

# DB_HOST NO va aquí — docker-compose lo fija en "database" internamente.

# ── Admin del panel ──────────────────────────────────────────
# Se crea automáticamente en el primer deploy.
# Si el correo ya existe en la BD, el INSERT se ignora (idempotente).
ADMIN_EMAIL=admin@tusitio.com
ADMIN_PASSWORD=OtraClaveSegura456!
ADMIN_NAME=Administrador
